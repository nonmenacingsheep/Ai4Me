# ─────────────────────────────────────────────────────────────
# Ai4Me — copy this file to ".env" and fill in what you use.
# At minimum, set ONE cloud API key (or run a local Ollama model).
# ─────────────────────────────────────────────────────────────

# ─── Character ───────────────────────────────────────────────
# Her name. Also changeable later in Settings → Character name.
AITHA_NAME=Aitha
# Which model she runs on by default (must match a key you set below,
# or a local Ollama model name). Examples: deepseek-chat, gpt-4o-mini,
# anthropic/claude-3.5-sonnet (via OpenRouter), llama3.1 (local).
AITHA_MODEL=deepseek-chat

# ─── Cloud LLM providers (set the one(s) you want; leave the rest blank) ───
# All are OpenAI-compatible. OpenRouter is a gateway — one key unlocks
# Claude, Gemini, Llama, and more.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ─── Local model (optional) ──────────────────────────────────
# Ollama is NOT auto-started. Run `ollama serve` yourself and any local
# models you've pulled will appear in the model dropdown automatically.
OLLAMA_NUM_CTX=4096
OLLAMA_KEEP_ALIVE=30m

# ─── Vision / "her eyes" (optional) ──────────────────────────
# A SEPARATE multimodal model that describes images you send her, so your main
# chat model can stay text-only. Also pickable in Settings → General → Her eyes.
# Pull one first, e.g. `ollama pull llava`. (llama3.2-vision needs a recent Ollama
# build — older ones error with: unknown model architecture: 'mllama'.)
AITHA_VISION_MODEL=

# ─── Text-to-speech (Kokoro) ─────────────────────────────────
TTS_ENABLED=1
TTS_VOICE=af_heart
# Where her voice plays out. Use a virtual-audio-cable input here only if
# you route her through a voice changer; otherwise your normal speakers/headset.
TTS_OUTPUT_DEVICE=CABLE Input (VB-Audio Virtual Cable)
# Force a device for Kokoro: cuda / cpu (auto-detected if blank)
# KOKORO_DEVICE=

# ─── Voice presence — "The Boiled One" horror voice (optional) ─
# When "The Boiled One" is on (Settings → Behavior), ALL her speech is voiced via
# eSpeak NG's breathy/distorted rasp (Kokoro can't make this sound), routed through
# your voice changer so it's still her underneath. Needs eSpeak NG installed
# (https://github.com/espeak-ng/espeak-ng/releases). Without it she just softens her
# normal Kokoro voice. These tune the horror voice's character:
# ESPEAK_WHISPER_VOICE=en-us+whisperf
# ESPEAK_WHISPER_WPM=155
# ESPEAK_WHISPER_PITCH=35

# ─── Code workspace (optional) ───────────────────────────────
# Her own Python sandbox (Settings -> Behavior -> Capabilities -> Code workspace,
# OFF by default). Files live in ~/.ai4me/workspace; runs are confined to that dir
# and hard-killed after the timeout. Python only.
# AITHA_CODE_TIMEOUT=10
# AITHA_MAX_CODE_RUNS=4

# ─── Speech-to-text (faster-whisper, hands-free voice input) ─
# base.en is small & fast; small.en is more accurate (~480MB).
AITHA_WHISPER_MODEL=base.en
# AITHA_WHISPER_DEVICE=cuda
# AITHA_WHISPER_COMPUTE=float16

# ─── Voice changer (optional) ────────────────────────────────
# Absolute path to MMVCServerSIO's start_http.bat to have Ai4Me launch it.
# Leave blank to skip (TTS works fine without it).
VOICE_CHANGER_BAT=

# ─── Web search (optional) ───────────────────────────────────
# Lets her search the web during exploration. 1 to enable.
AITHA_WEB_SEARCH=0

# ─── Spotify (optional) ──────────────────────────────────────
# Lets her see what you're playing, read your taste, build/grow playlists,
# and (with Premium) control playback. See the "Connecting Spotify" tutorial
# in the README for how to get these values from the Spotify dashboard.
# The redirect URI must be registered EXACTLY as below and match the app's port.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:7823/spotify/callback
