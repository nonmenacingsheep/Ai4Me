# ─────────────────────────────────────────────────────────────
# Ai4Me — copy this file to ".env" and fill in what you use.
# At minimum, set ONE cloud API key (or run a local Ollama model).
# ─────────────────────────────────────────────────────────────

# ─── Character ───────────────────────────────────────────────
# Her name. Also changeable later in Settings → Character name.
AITHA_NAME=Aitha
# Which model she runs on by default (must match a key you set below,
# or a local Ollama model name). Examples: deepseek-chat, gpt-4o-mini,
# anthropic/claude-3.5-sonnet (via OpenRouter), llama3.1 (local).
AITHA_MODEL=deepseek-chat

# ─── Cloud LLM providers (set the one(s) you want; leave the rest blank) ───
# All are OpenAI-compatible. OpenRouter is a gateway — one key unlocks
# Claude, Gemini, Llama, and more.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ─── Local model (optional) ──────────────────────────────────
# Ollama is NOT auto-started. Run `ollama serve` yourself and any local
# models you've pulled will appear in the model dropdown automatically.
OLLAMA_NUM_CTX=4096
OLLAMA_KEEP_ALIVE=30m

# ─── Text-to-speech (Kokoro) ─────────────────────────────────
TTS_ENABLED=1
TTS_VOICE=af_heart
# Where her voice plays out. Use a virtual-audio-cable input here only if
# you route her through a voice changer; otherwise your normal speakers/headset.
TTS_OUTPUT_DEVICE=CABLE Input (VB-Audio Virtual Cable)
# Force a device for Kokoro: cuda / cpu (auto-detected if blank)
# KOKORO_DEVICE=

# ─── Speech-to-text (faster-whisper, hands-free voice input) ─
# base.en is small & fast; small.en is more accurate (~480MB).
AITHA_WHISPER_MODEL=base.en
# AITHA_WHISPER_DEVICE=cuda
# AITHA_WHISPER_COMPUTE=float16

# ─── Voice changer (optional) ────────────────────────────────
# Absolute path to MMVCServerSIO's start_http.bat to have Ai4Me launch it.
# Leave blank to skip (TTS works fine without it).
VOICE_CHANGER_BAT=

# ─── Web search (optional) ───────────────────────────────────
# Lets her search the web during exploration. 1 to enable.
AITHA_WEB_SEARCH=0
